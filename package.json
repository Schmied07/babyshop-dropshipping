{
  "name": "babyshop-dropshipping-api",
  "version": "1.0.0",
  "description": "API de gestion dropshipping complète pour marcherbien.fr - Gestion MongoDB, synchronisation WooCommerce, fournisseurs européens",
  "main": "api_dropshipping.js",
  "type": "module",
  "scripts": {
    "start": "node api_dropshipping.js",
    "dev": "nodemon api_dropshipping.js",
    "test": "jest --coverage",
    "seed": "node mongodb_babyshop_seed.js",
    "seed:suppliers": "node scripts/seed_suppliers.js",
    "backup": "node scripts/backup_mongo.js",
    "sync:wp": "node scripts/sync_wordpress.js",
    "update:prices": "node scripts/update_supplier_prices.js",
    "pm2:start": "pm2 start api_dropshipping.js --name babyshop-api",
    "pm2:stop": "pm2 stop babyshop-api",
    "pm2:logs": "pm2 logs babyshop-api",
    "pm2:restart": "pm2 restart babyshop-api"
  },
  "keywords": [
    "dropshipping",
    "ecommerce",
    "woocommerce",
    "mongodb",
    "nodejs",
    "api"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "axios": "^1.5.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.0",
    "express-validator": "^7.0.0",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.0.0",
    "mongodb": "^6.3.0",
    "cron": "^3.1.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.50.0",
    "prettier": "^3.0.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/justme/babyshop-dropshipping.git"
  },
  "bugs": {
    "url": "https://github.com/justme/babyshop-dropshipping/issues"
  },
  "homepage": "https://github.com/justme/babyshop-dropshipping#readme"
}
